#: .././wpu_redirection_extended.php:313
msgid ""
"Provide the URL of an external sitemap (XML or sitemap index, optionally "
"gzipped). A CSV will be generated with one source URL per line and an empty "
"target column."
msgstr ""
"Indiquez l'URL d'un plan de site externe (au format XML ou index de plan de "
"site, éventuellement compressé au format gzip). Un fichier CSV sera généré, "
"contenant une URL source par ligne et une colonne de destination vide."

#: .././wpu_redirection_extended.php:316
msgid "Sitemap URL"
msgstr "URL du plan du site"

#: .././wpu_redirection_extended.php:320
msgid "Exclude home"
msgstr "Exclure la page d'accueil"

#: .././wpu_redirection_extended.php:321
msgid "Exclude the home URL (/) from the generated CSV"
msgstr "Exclure l'URL d'accueil (/) du fichier CSV généré"

#: .././wpu_redirection_extended.php:325
msgid "Exclude existing slugs"
msgstr "Exclure les slugs existants"

