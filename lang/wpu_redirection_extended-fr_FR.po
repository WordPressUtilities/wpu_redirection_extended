msgid "Existing slugs will be removed"
msgstr "Les slugs existants seront retirés"

#: .././wpu_redirection_extended.php:350
msgid "Filter existing redirections"
msgstr "Filtrer les redirections existantes"

#: .././wpu_redirection_extended.php:351
msgid "Existing redirections will be removed"
msgstr "Les redirections existantes seront supprimées"

#: .././wpu_redirection_extended.php:356
msgid "Get a list of errors"
msgstr "Obtenir une liste d’erreurs"

